# EditorConfig keeps indentation, charset, and line endings consistent across
# every editor and IDE on the team. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# Markdown: trailing whitespace can be a deliberate hard line break.
[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

# npm-managed files: leave formatting to the tooling.
[package-lock.json]
indent_style = unset
indent_size = unset
